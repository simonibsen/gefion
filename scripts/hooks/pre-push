#!/bin/bash
#
# Pre-push: quick smoke tests + data dictionary drift check (~5s).
# The FULL unit suite runs in CI on every PR (.github/workflows/ci.yml);
# this hook only catches the obvious breakage before it leaves the machine.

echo "Running smoke tests + drift check before push..."
echo ""

# Fast core files only: generator/dictionary, CLI entrypoint (--help via
# subprocess), config parsing, health checks. Keep this set snappy (<20s).
OTEL_ENABLED=false .venv/bin/python -m pytest -q -x \
    tests/test_data_dictionary_generator.py \
    tests/test_cli_init.py \
    tests/test_config.py \
    tests/test_health.py

if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Smoke tests failed! Push aborted."
    echo ""
    echo "Run the full unit suite locally with:"
    echo "  OTEL_ENABLED=false .venv/bin/python -m pytest tests/ -q"
    echo "Full suite with DB tests:"
    echo "  ENABLE_DB_TESTS=1 DATABASE_URL=\"postgresql://gefion:gefionpass@localhost:6432/gefion\" OTEL_ENABLED=false .venv/bin/python -m pytest tests/ -v"
    echo ""
    exit 1
fi

# Hermetic: reads sql/schema.sql + sql/migrations/*.sql, no DB needed.
.venv/bin/python scripts/gen_data_dictionary.py --check
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ docs/DATA_DICTIONARY.md is stale! Push aborted."
    echo ""
    echo "Regenerate and commit it:"
    echo "  .venv/bin/python scripts/gen_data_dictionary.py --write"
    echo ""
    exit 1
fi

echo ""
echo "✅ Smoke tests + drift check passed! Proceeding with push..."
echo "   (CI runs the full suite on the PR.)"
echo ""
