#!/bin/bash

echo "Running fast tests before push..."
echo ""

# Run fast unit tests only (skip slow ML tuning tests and DB tests)
# Full test suite should be run separately:
#   ENABLE_DB_TESTS=1 DATABASE_URL="postgresql://g2:g2pass@localhost:6432/g2" OTEL_ENABLED=false .venv/bin/python -m pytest tests/ -v
OTEL_ENABLED=false .venv/bin/python -m pytest tests/ -q \
    --ignore=tests/test_ml_hyperparameter_tuning.py \
    --ignore=tests/test_ml_gpu_support.py \
    -x

# Check exit code
if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Tests failed! Push aborted."
    echo ""
    echo "Fix the failing tests before pushing."
    echo "To run full suite with DB tests:"
    echo "  ENABLE_DB_TESTS=1 DATABASE_URL=\"postgresql://g2:g2pass@localhost:6432/g2\" OTEL_ENABLED=false .venv/bin/python -m pytest tests/ -v"
    echo ""
    exit 1
fi

echo ""
echo "✅ All tests passed! Proceeding with push..."
echo ""
