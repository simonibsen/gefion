POSTGRES_USER=gefion
POSTGRES_PASSWORD=gefionpass
POSTGRES_DB=gefion
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./db

# ALPHAVANTAGE_API_KEY=your_key_here
# DATABASE_URL for local development (outside docker)
# Template: postgresql://{USER}:{PASSWORD}@localhost:{POSTGRES_PORT}/{DB}
# Must manually match POSTGRES_PORT value above (no variable expansion in .env files)
# DATABASE_URL=postgresql://gefion:gefionpass@localhost:5432/gefion

# Observability (Grafana Tempo)
# Set OTEL_ENABLED=false or unset to disable tracing (zero overhead)
OTEL_ENABLED=true
OTEL_SERVICE_NAME=gefion
OTEL_EXPORTER=otlp
OTEL_OTLP_ENDPOINT=http://localhost:4317
OTEL_SAMPLING_RATE=1.0

# Tempo / Grafana ports (used by docker/tempo/docker-compose.tempo.yml)
TEMPO_HTTP_PORT=3200
TEMPO_GRPC_PORT=4317
TEMPO_OTLP_HTTP_PORT=4318
GRAFANA_PORT=3000
